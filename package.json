{
  "name": "syncnexus",
  "version": "1.0.0",
  "description": "Real-time chat platform with RAG-powered AI assistant",
  "main": "src/index.js",
  "type": "commonjs",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "worker": "node src/worker.js",
    "test": "jest --runInBand --forceExit",
    "test:ci": "jest --runInBand --forceExit --ci",
    "lint": "eslint src/ --ext .js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.600.0",
    "@aws-sdk/s3-request-presigner": "^3.600.0",
    "@google/genai": "^2.9.0",
    "@prisma/client": "^5.16.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "@socket.io/redis-emitter": "^5.1.0",
    "bcrypt": "^5.1.1",
    "bullmq": "^5.12.0",
    "chromadb": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "mammoth": "^1.8.0",
    "morgan": "^1.10.0",
    "multer": "^2.2.0",
    "pdf-parse": "^1.1.1",
    "pino": "^9.3.1",
    "pino-pretty": "^11.2.1",
    "socket.io": "^4.7.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "pdf-lib": "^1.17.1",
    "pdfkit": "^0.19.1",
    "prisma": "^5.16.0",
    "socket.io-client": "^4.7.5",
    "supertest": "^7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testTimeout": 30000,
    "testEnvironmentOptions": {},
    "globalSetup": "<rootDir>/tests/global-setup.js",
    "setupFiles": [
      "<rootDir>/tests/setup.js"
    ]
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
