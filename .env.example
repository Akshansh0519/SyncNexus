NODE_ENV=development
PORT=3000

# PostgreSQL
DATABASE_URL=postgresql://postgres:password@localhost:5432/syncnexus

# Redis
REDIS_URL=redis://localhost:6379

# ChromaDB
CHROMA_URL=http://localhost:8000

# MinIO (S3-compatible object storage)
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=syncnexus-files

# JWT Secrets — REQUIRED — min 32 chars, MUST be different from each other
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
# ⚠️  NEVER commit real values here. Use your cloud secret manager in production.
ACCESS_TOKEN_SECRET=
REFRESH_TOKEN_SECRET=

# Frontend origin for CORS (comma-separated for multiple)
CLIENT_URL=http://localhost:3001

# AI / Embeddings — leave empty to use mock mode (no Gemini calls)
# ⚠️  Never commit a real API key. Use environment variables in production.
GEMINI_API_KEY=

# Optional: override the LLM model (default: gemini-2.5-flash)
# LLM_MODEL=gemini-2.5-flash
